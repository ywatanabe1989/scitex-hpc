# scitex-hpc environment variables
#
# `cp .env.example .env` and edit. Loaded automatically when scitex-hpc
# initializes; explicit JobConfig fields still take precedence.

# Default cluster head (login-shell SSH target).
# SCITEX_HPC_HOST=spartan

# Default SLURM partition. Per-cluster names vary (e.g. sapphire, cascade).
# SCITEX_HPC_PARTITION=sapphire

# Per-job resource defaults.
# SCITEX_HPC_CPUS=16
# SCITEX_HPC_TIME=00:20:00
# SCITEX_HPC_MEM=128G

# Where rsync drops local sources on the cluster (relative to $HOME).
# SCITEX_HPC_REMOTE_BASE=~/proj

# Override the lease state dir (tests use this to avoid touching ~/.scitex/).
# Default: ~/.scitex/hpc/leases/
# SCITEX_HPC_LEASE_DIR=
